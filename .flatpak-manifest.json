{
    "id": "org.kde.okteta",
    "branch": "work/kossebau/kf6",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.10",
    "sdk": "org.kde.Sdk",
    "command": "okteta",
    "tags": ["nightly"],
    "desktop-file-name-suffix": " (Nightly)",
    "finish-args": [
        "--device=dri",
        "--filesystem=host",
        "--share=ipc",
        "--share=network",
        "--socket=cups",
        "--socket=wayland",
        "--socket=fallback-x11"
    ],
    "cleanup": [
    ],
    "modules": [
        {
            "name": "okteta",
            "buildsystem": "cmake",
            "config-opts": [
                "-DCMAKE_UNITY_BUILD=ON",
                "-DCMAKE_UNITY_BUILD_BATCH_SIZE=0",
                "-DBUILD_TESTING=OFF",
                "-DBUILD_DEVEL=OFF",
                "-DBUILD_DESIGNERPLUGIN=OFF",
                "-DBUILD_KPARTSPLUGIN=OFF",
                "-DBUILD_DOC=OFF"
            ],
            "sources": [ { "type": "dir", "path": ".", "branch": "work/kossebau/kf6" } ]
        }
    ]
}
